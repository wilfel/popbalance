    def advance(self, wet_pop, dry_pop, gas, dt):       # split this by wet and dry??
        # this function is run each time step
        rho_water = 1000    # density in kg/m^3
        d = wet_pop.grid.centers        # diameters of wet population (nm)
        d_m = d * 1E-9
        widths = wet_pop.grid.widths    # width of each bin size
        

        
        dm_dt = self.wet_mass_loss(d)      #Evaporation-driven droplet drying using mass transfer equation
        #dm_dt = self.hertz_knudsen_massloss(d)     # Don't use this one

        dd_dt = (2/(np.pi*rho_water*(d_m)**2))*dm_dt  # diameter change rate in m/s
        
        #print(np.min(dd_dt), np.max(dd_dt))
        #print(np.max(abs(dd_dt)*1e9*dt))
        #print(np.min(widths))
        
        N_old = wet_pop.N.copy()        # saves initial numbers in each bin as N_old
        N_new = np.zeros_like(N_old)    # initialize new as array of zeros

        for j0 in range(wet_pop.grid.n_bins):  # iterate over original wet bin sizes
            d_dry = wet_pop.dry_size[j0]    # save corresponding dry size

            for i in range(wet_pop.grid.n_bins):  # iterate over current wet bin sizes
                Nij = N_old[i, j0]  # initial number in a specific bin along with its original bin size
                
                if Nij == 0:    # pass if bin is empty
                    continue
                d_exit = d[i] + dd_dt[i] *1E9 * dt   # calculate new size in this step

                if d_exit <= d_dry: # fully dry particles
                    # 1. Find the index of the bin that actually matches the dry size
                    # We use the grid edges to find where d_dry fits
                    dry_bin_index = np.searchsorted(wet_pop.grid.edges, d_dry) - 1
                    dry_bin_index = np.clip(dry_bin_index, 0, wet_pop.grid.n_bins - 1)
                    
                    # 2. Add the particles to THAT bin in the dry population
                    dry_pop.N[dry_bin_index] += Nij
                    #dry_pop.N[j0] += Nij    # add particles to the dry population
                    # dried particles are 'subtracted' from the wet population by simply not adding them to the new
                    continue
                else:
                    # destination bin
                    h = np.searchsorted(d, d_exit) - 1  # find where to insert d_exit to keep d sorted; -1 to put bin just below
                    h = np.clip(h, 0, len(d) - 1)   # limit to length of array

                    frac = min(1.0, abs(dd_dt[i] *1E9 * dt) / widths[i]) # what fraction of particles leave during this timestep
                        # divide delta d by bin width to determine how many leaves (ex. delta d = 0.2*width = 20% leave)

                    N_new[i, j0] += Nij * (1 - frac)    # particles that stay
                    N_new[h, j0] += Nij * frac          # particles that leave
        wet_pop.N[:] = N_new    # update array

        dm_SA_dt = self.wet_SA_mass_loss(d)
        #dm_SA_dt_total = dm_SA_dt * N_bin
        
        N_bin = wet_pop.N.sum(axis=1) #sum across origin bins → total particles in each current size bin
        total_loss = dm_SA_dt * N_bin
        wet_pop.mass_SA_liq = wet_pop.mass_SA_liq - total_loss * dt  # kg CHECK THIS????        
        wet_pop.conc_SA_liq = (wet_pop.mass_SA_liq / ((d_m)**3 * np.pi /6))   # 1 g/l = 1 kg/m^3
        gas.mass_SA_gas += np.sum(dm_SA_dt*N_bin) * dt    # kg
        d_dry = dry_pop.grid.centers * 1E-9
        
        N_old_dry = dry_pop.N.copy()
        N_new_dry = np.zeros_like(N_old_dry)
        widths_dry = dry_pop.grid.widths   # nm
        dd_DRY_dt = self.dry_SA_condensation(gas) # m/s
        for i in range(dry_pop.grid.n_bins):

                    Nij = N_old_dry[i]
                    if Nij == 0:
                        continue

                    d_new = d_dry[i] + dd_DRY_dt[i]*1E9 * dt

                    # Prevent negative or unphysical shrinkage below original dry core
                    d_new = max(d_new, d_dry[i])

                    # Find destination bin
                    h = np.searchsorted(d_dry, d_new) - 1
                    h = np.clip(h, 0, dry_pop.grid.n_bins - 1)

                    frac = min(1.0, abs(dd_DRY_dt[i]*1E9 * dt) / widths_dry[i])

                    N_new_dry[i] += Nij * (1 - frac)
                    N_new_dry[h] += Nij * frac

        dry_pop.N[:] = N_new_dry
        
