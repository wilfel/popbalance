# --- Classes ---
class SizeGrid:
    def __init__(self, d_min, d_max, n_bins, dt, total_time):
        self.edges = np.logspace(np.log10(d_min), np.log10(d_max), n_bins + 1)  # edges of each size bin (nm)
        self.centers = np.sqrt(self.edges[:-1] * self.edges[1:])    # center diameter of each bin (nm)
        self.widths = self.edges[1:] - self.edges[:-1]  # length of each bin (nm)
        self.n_bins = n_bins    # number of bins
        self.n_steps = int(total_time / dt) # number of time steps
        self.delta_log_d = np.log10(self.edges[1]) - np.log10(self.edges[0])
    
    def init_lognormal(self, N0, d_g, sigma_g):
        return (N0 /
                (self.centers * np.sqrt(2*np.pi) * np.log(sigma_g)) *
                np.exp(-(np.log(self.centers / d_g))**2 /
                    (2 * (np.log(sigma_g))**2)))

class Population:
    def __init__(self, grid, n_density_initial, wet):
        self.grid = grid    
        self.wet = True # wet or dry
        self.n_density = n_density_initial
        self.N0 = n_density_initial * grid.widths   # initial total number in each bin
        
        if wet:
            self.N = np.zeros((grid.n_bins, grid.n_bins))   # N[current_bin, origin_bin] 
            for j in range(grid.n_bins):
                self.N[j, j] = self.N0[j]   # current and initial bin ID initialized equal
            self.calc_dry_size()
            self.init_composition()
            self.conc_SA_liq = 0.75     # kg/m^3
            self.conc_AS_liq = 0.25     # kg/m^3
            self.mass_SA_liq = ((grid.centers*1E-9)**3 * np.pi /6) * self.conc_SA_liq * 1000   # g
        else:
            self.N = self.N0
            self.dry_size = None

    def calc_dry_size(self):
        d_o = self.grid.centers     # initial diameter center of each bin
        x_max_sa = 83 / (1000 + 83)     # max weight frac. of SA based on solubility limit (83g/L = 83g/1000L)
        x_solute_dry = x_max_sa / 0.75  # max weight frac. of solute assuming 75% SA
        x_solute_o = 0.001  # initial solute concentration is 1 g/L = 1g/1000g
        #self.dry_size = d_o * (x_solute_o / x_solute_dry) ** (1 / 3)    # proportionality relationship double check this
        self.dry_size = (d_o * (1000*x_solute_o/1600)**(1/3))  # actually 1600 just changed for pure AS for now
    
    def init_composition(self, x_solute_o=0.001, rho_water=1000):
        d = self.grid.centers * 1e-9
        V = np.pi/6 * d**3
        m_total = rho_water * V
        self.m_solute = x_solute_o * m_total
        self.m_water = (1 - x_solute_o) * m_total

    def summary_statistics(self):
        """
        Calculate and store summary statistics of current size distribution.
        """
        pass

